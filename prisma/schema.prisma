generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USERS ───

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(EDITOR)
  posts         Post[]
  caseStudies   CaseStudy[]
  activities    ActivityLog[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── BLOG / POSTS ───

model Post {
  id              String     @id @default(cuid())
  titleId         String
  titleEn         String?
  slug            String     @unique
  excerptId       String?    @db.Text
  excerptEn       String?    @db.Text
  bodyId          String     @db.Text
  bodyEn          String?    @db.Text
  featuredImage      String?
  featuredImageAlt   String?
  metaTitle          String?
  metaDescription    String?
  metaTitleEn        String?
  metaDescriptionEn  String?
  slugEn             String?  @unique
  ogImage            String?
  focusKeyword    String?
  readingTime     Int?
  wordCount       Int?
  status          PostStatus @default(DRAFT)
  authorId        String
  author          User       @relation(fields: [authorId], references: [id])
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  tags            PostTag[]
  versions        PostVersion[]
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
  @@index([categoryId])
}

enum PostStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model PostVersion {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  titleId   String
  bodyId    String   @db.Text
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  nameId    String
  nameEn    String?
  slug      String   @unique
  sortOrder Int      @default(0)
  posts     Post[]
  createdAt DateTime @default(now())
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([postId, tagId])
}

// ─── SERVICES ───

model Service {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  descriptionId   String        @db.Text
  descriptionEn   String?       @db.Text
  shortDescId     String?
  shortDescEn     String?
  icon            String?
  color           String
  funnelPosition  String?
  sortOrder       Int           @default(0)
  seoSchema       Json?
  metaTitle       String?
  metaDescription String?
  pricingTiers      PricingTier[]
  addOns            ServiceAddOn[]
  caseStudies       CaseStudy[]
  caseStudyServices CaseStudyService[]
  isActive          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PricingTier {
  id         String  @id @default(cuid())
  serviceId  String
  service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tierName   String
  priceLabel String
  priceValue Int?
  features   Json
  isPopular  Boolean @default(false)
  sortOrder  Int     @default(0)
}

model ServiceAddOn {
  id          String  @id @default(cuid())
  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  priceLabel  String?
  isActive    Boolean @default(true)
}

// ─── CASE STUDIES / PORTFOLIO ───

model Industry {
  id          String      @id @default(cuid())
  nameId      String
  nameEn      String?
  slug        String      @unique
  accentColor String?
  caseStudies CaseStudy[]
  createdAt   DateTime    @default(now())
}

model CaseStudy {
  id              String              @id @default(cuid())
  // Legacy fields (keep for backward compat)
  title           String
  industry        String
  challenge       String              @db.Text
  strategy        String              @db.Text
  results         String              @db.Text
  thumbnail       String?
  serviceId       String?
  service         Service?            @relation(fields: [serviceId], references: [id])
  // Multilingual fields (new)
  titleId         String?
  titleEn         String?
  subtitleId      String?
  subtitleEn      String?
  summaryId       String?             @db.Text
  summaryEn       String?             @db.Text
  slugEn          String?             @unique
  seoTitleId      String?
  seoTitleEn      String?
  seoDescId       String?
  seoDescEn       String?
  ogImage         String?
  featuredImage   String?
  durationLabel   String?
  clientWebsite   String?
  featured        Boolean             @default(false)
  industryId      String?
  industryRel     Industry?           @relation(fields: [industryId], references: [id])
  // Relations
  slug            String              @unique
  clientName      String
  clientLogo      String?
  authorId        String?
  author          User?               @relation(fields: [authorId], references: [id])
  metrics         CaseMetric[]
  testimonial     Testimonial?
  blocks          CaseStudyBlock[]
  caseStudyServices CaseStudyService[]
  status          PostStatus          @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model CaseStudyBlock {
  id          String    @id @default(cuid())
  caseStudyId String
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
  blockType   BlockType
  sortOrder   Int       @default(0)
  isVisible   Boolean   @default(true)
  data        Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([caseStudyId, sortOrder])
}

model CaseStudyService {
  caseStudyId String
  serviceId   String
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([caseStudyId, serviceId])
}

enum BlockType {
  HERO
  OVERVIEW
  CLIENT_SNAPSHOT
  NARRATIVE
  METRIC_GRID
  TIMELINE
  CHART
  BEFORE_AFTER
  GALLERY
  VIDEO
  QUOTE
  SERVICES_USED
  RELATED_CASES
  CTA
  LEAD_FORM
  FAQ
  RICH_TEXT
}

model CaseMetric {
  id           String    @id @default(cuid())
  caseStudyId  String
  caseStudy    CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
  metricLabel  String
  beforeValue  String
  afterValue   String
  sortOrder    Int       @default(0)
}

model Testimonial {
  id            String    @id @default(cuid())
  caseStudyId   String?   @unique
  caseStudy     CaseStudy? @relation(fields: [caseStudyId], references: [id])
  clientName    String
  clientTitle   String
  clientPhoto   String?
  quote         String    @db.Text
  companyName   String
  isHighlighted Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

// ─── FLEXIBLE PAGES ───

model Page {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  status          PostStatus    @default(DRAFT)
  sections        PageSection[]
  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())
}

model PageSection {
  id           String  @id @default(cuid())
  pageId       String
  page         Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sectionType  String
  content      Json
  sortOrder    Int     @default(0)
  isVisible    Boolean @default(true)
}

// ─── MEDIA LIBRARY ───

model Media {
  id         String   @id @default(cuid())
  filename   String
  url        String
  altText    String?
  mimeType   String
  fileSize   Int
  width      Int?
  height     Int?
  folder     String   @default("general")
  uploadedAt DateTime @default(now())
}

// ─── SITE SETTINGS ───

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

// ─── ACTIVITY LOG ───

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  entityTitle String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

// ─── CONTACT SUBMISSIONS ───

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  phone       String?
  services    Json?
  budgetRange String?
  timeline    String?
  message     String   @db.Text
  source      String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── CTA WIDGETS ───

model CtaWidget {
  id                   String       @id @default(cuid())
  name                 String
  templateType         CtaTemplate
  heading              String?
  subheading           String?
  buttonText           String?
  buttonUrl            String
  secondaryButtonText  String?
  secondaryButtonUrl   String?
  backgroundImage      String?
  backgroundColor      String?
  textColor            String?
  cssClass             String?
  gaEventCategory      String?
  gaEventLabel         String?
  dataAttributes       Json?
  placement            CtaPlacement
  paragraphIndex       Int?
  targetingType        CtaTargeting @default(ALL_POSTS)
  targetPostIds        String[]
  targetTagIds         String[]
  targetCategoryIds    String[]
  isActive             Boolean      @default(true)
  startDate            DateTime?
  endDate              DateTime?
  showOnMobile         Boolean      @default(true)
  showOnDesktop        Boolean      @default(true)
  maxImpressions       Int?
  dismissible          Boolean      @default(true)
  dismissDuration      Int          @default(7)
  displayTrigger       String?
  displayDelay         Int?
  scrollDepthThreshold Float?
  countdownLabel       String?
  imagePosition        String?
  emoji                String?
  sponsoredLabel       Boolean      @default(false)
  impressionCount      Int          @default(0)
  clickCount           Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

enum CtaTemplate {
  HERO_BANNER
  SERVICE_CARD
  INLINE_CALLOUT
  CUSTOM_IMAGE
  MINIMAL_STRIP
  FLOATING_NOTIFICATION
  SPLIT_VISUAL
  COUNTER_URGENCY
}

enum CtaPlacement {
  INLINE
  ABOVE_FOLD
  BELOW_ARTICLE
  SIDEBAR
  STICKY_BOTTOM
  BETWEEN_PARAGRAPHS
  AFTER_TOC
}

enum CtaTargeting {
  ALL_POSTS
  SPECIFIC_POSTS
  BY_TAG
  BY_CATEGORY
  EXCLUDE_POSTS
}
